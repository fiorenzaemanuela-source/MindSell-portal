rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /studenti/{uid} {
      allow read, write: if request.auth != null;
    }

    match /studenti/{uid}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    match /aiCoach/{uid}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    match /courses/{courseId}/{sub=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /chat/{chatId}/{sub=**} {
      allow read, write: if request.auth != null;
    }

    match /materiali/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /guide/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /libreria/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /annunci/{doc} {
      allow read, write: if request.auth != null;
    }

    match /domande/{doc} {
      allow read, write: if request.auth != null;
    }

    match /referrals/{doc} {
      allow read, write: if request.auth != null;
    }

    match /referralPost/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /referralBrochure/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /notifiche/{uid} {
      allow read, write: if request.auth != null;
    }

    match /richieste/{doc} {
      allow read, write: if request.auth != null;
    }

    match /recensioni/{doc} {
      allow read, write: if request.auth != null;
    }

    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Video Library — lettura autenticata, scrittura solo server-side
    match /videoLibrary/{videoId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
